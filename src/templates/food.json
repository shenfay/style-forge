[
  {
    "id": "food-scan-result-mobile",
    "name": "扫码结果页-移动端",
    "scene": "food",
    "device": "mobile",
    "type": "result",
    "description": "食品扫码结果展示页面，显示成分分析和风险提示",
    "defaultStyle": {
      "backgroundColor": "#FFFDF5",
      "primaryColor": "#5F7D2E",
      "cornerRadius": "medium",
      "cardStyle": "borderless",
      "titleBarStyle": "white-underline",
      "switcherStyle": "underline",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "顶部标题",
          "type": "header",
          "height": "44px",
          "components": ["back-button", "title", "share-button"]
        },
        {
          "id": "risk-indicator",
          "name": "风险等级",
          "type": "content",
          "components": ["risk-level", "risk-switcher", "summary"]
        },
        {
          "id": "product-info",
          "name": "产品信息",
          "type": "content",
          "components": ["product-name", "product-details", "barcode"]
        },
        {
          "id": "ingredients",
          "name": "成分分析",
          "type": "content",
          "components": ["ingredient-list", "risk-badges"]
        },
        {
          "id": "footer",
          "name": "底部操作",
          "type": "footer",
          "height": "56px",
          "components": ["favorite-button", "confirm-button"]
        }
      ]
    },
    "aiPrompt": {
      "title": "食品扫码结果页（移动端）",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "顶部标题栏、风险等级显示区、产品信息卡片、成分分析列表、底部操作栏"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 风险等级：红/黄/绿三档切换显示\n2. 产品信息：名称、净含量、保质期、条形码\n3. 成分分析：成分名称、描述、风险标签\n4. 底部操作：收藏、确认食用按钮"
        },
        {
          "heading": "## 交互说明",
          "content": "- 风险等级支持红黄绿三档切换\n- 成分列表可上下滚动\n- 底部操作栏固定在屏幕底部\n- 风险标签使用语义色标识"
        }
      ]
    }
  },
  {
    "id": "food-health-tracker-mobile",
    "name": "健康记录页-移动端",
    "scene": "food",
    "device": "mobile",
    "type": "list",
    "description": "食品健康记录列表，展示历史扫码记录",
    "defaultStyle": {
      "backgroundColor": "#F5FAF5",
      "primaryColor": "#2E7D67",
      "cornerRadius": "medium",
      "cardStyle": "shadow",
      "titleBarStyle": "frosted-glass",
      "switcherStyle": "pill",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "顶部标题",
          "type": "header",
          "height": "44px",
          "components": ["back-button", "title", "scan-button"]
        },
        {
          "id": "stats",
          "name": "统计概览",
          "type": "content",
          "components": ["stats-cards", "chart"]
        },
        {
          "id": "content",
          "name": "记录列表",
          "type": "content",
          "components": ["history-list", "filter-tabs"]
        }
      ]
    },
    "aiPrompt": {
      "title": "食品健康记录页（移动端）",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "顶部标题栏（带扫码入口）、统计概览卡片、历史记录列表"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 统计卡片：总数、安全数量、警告数量\n2. 历史记录：商品名称、扫码时间、风险等级标签\n3. 筛选：按时间、风险等级筛选"
        }
      ]
    }
  }
]
