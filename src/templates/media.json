      "backgroundColor": "#F9F8F4",
      "primaryColor": "#2E7D32",
      "cornerRadius": "medium",
      "cardStyle": "shadow",
      "titleBarStyle": "frosted-glass",
      "switcherStyle": "pill",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "顶部导航",
          "type": "header",
          "height": "56px",
          "components": ["logo", "search-button"]
        },
        {
          "id": "filters",
          "name": "筛选栏",
          "type": "content",
