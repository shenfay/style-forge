[
  {
    "id": "finance-account-mobile",
    "name": "账户总览-移动端",
    "scene": "finance",
    "device": "mobile",
    "type": "home",
    "description": "金融账户总览页，展示资产和负债情况",
    "defaultStyle": {
      "backgroundColor": "#F5F7FA",
      "primaryColor": "#00C853",
      "cornerRadius": "medium",
      "cardStyle": "shadow",
      "titleBarStyle": "colored-bg",
      "switcherStyle": "pill",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "资产总览",
          "type": "header",
          "height": "180px",
          "components": ["total-assets", "asset-chart", "eye-toggle"]
        },
        {
          "id": "quick-actions",
          "name": "快捷操作",
          "type": "content",
          "components": ["transfer", "recharge", "withdraw", "more"]
        },
        {
          "id": "accounts",
          "name": "账户列表",
          "type": "content",
          "components": ["bank-cards", "investment-accounts"]
        },
        {
          "id": "tabbar",
          "name": "底部导航",
          "type": "footer",
          "height": "56px",
          "components": ["tab-home", "tab-products", "tab-transactions", "tab-profile"]
        }
      ]
    },
    "aiPrompt": {
      "title": "金融账户总览（移动端）",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "顶部资产总览区（总资产+图表+隐藏按钮）、快捷操作入口、账户列表、底部Tab栏"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 资产展示：支持显示/隐藏金额\n2. 资产趋势：7日/30日折线图\n3. 快捷操作：转账、充值、提现、更多\n4. 账户卡片：银行卡、理财账户\n5. 底部Tab：首页、理财、交易、我的"
        }
      ]
    }
  },
  {
    "id": "finance-transactions-mobile",
    "name": "交易记录-移动端",
    "scene": "finance",
    "device": "mobile",
    "type": "list",
    "description": "金融交易记录列表，展示收支明细",
    "defaultStyle": {
      "backgroundColor": "#FFFFFF",
      "primaryColor": "#00C853",
      "cornerRadius": "small",
      "cardStyle": "borderless",
      "titleBarStyle": "white-underline",
      "switcherStyle": "pill",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "顶部标题",
          "type": "header",
          "height": "44px",
          "components": ["back-button", "title", "filter-icon"]
        },
        {
          "id": "summary",
          "name": "收支统计",
          "type": "content",
          "components": ["month-selector", "income-expense-summary"]
        },
        {
          "id": "transactions",
          "name": "交易列表",
          "type": "content",
          "components": ["date-group", "transaction-items"]
        },
        {
          "id": "tabbar",
          "name": "底部导航",
          "type": "footer",
          "height": "56px",
          "components": ["tab-home", "tab-products", "tab-transactions", "tab-profile"]
        }
      ]
    },
    "aiPrompt": {
      "title": "金融交易记录（移动端）",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "顶部标题栏、月度收支统计、按日期分组的交易列表、底部Tab栏"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 月份选择器：左右切换月份\n2. 收支统计：收入、支出、结余\n3. 交易项：图标、标题、金额（红绿区分收支）、时间\n4. 日期分组：今天、昨天、本周等\n5. 下拉筛选：按类型、金额筛选"
        }
      ]
    }
  }
]
