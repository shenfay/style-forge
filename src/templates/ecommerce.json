[
  {
    "id": "ecommerce-home-mobile",
    "name": "B2C商城首页",
    "scene": "ecommerce",
    "device": "mobile",
    "type": "home",
    "description": "B2C电商商城首页，包含搜索、轮播、分类导航、限时抢购、推荐商品等核心模块",
    "defaultStyle": {
      "backgroundColor": "#FFFFFF",
      "primaryColor": "#FF6B35",
      "cornerRadius": "medium",
      "cardStyle": "shadow",
      "titleBarStyle": "frosted-glass",
      "switcherStyle": "pill",
      "buttonStyle": "gradient",
      "badgeStyle": "rounded"
