[
  {
    "id": "social-feed-mobile",
    "name": "动态流-移动端",
    "scene": "social",
    "device": "mobile",
    "type": "home",
    "description": "社交社区动态流页面，展示好友发布的内容",
    "defaultStyle": {
      "backgroundColor": "#FFFFFF",
      "primaryColor": "#2E7D32",
      "cornerRadius": "medium",
      "cardStyle": "borderless",
      "titleBarStyle": "frosted-glass",
      "switcherStyle": "pill",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "顶部导航",
          "type": "header",
          "height": "56px",
          "components": ["logo", "search-button", "message-button"]
        },
        {
          "id": "stories",
          "name": "故事/状态",
          "type": "content",
          "height": "100px",
          "components": ["story-carousel"]
        },
        {
          "id": "content",
          "name": "动态列表",
          "type": "content",
          "components": ["post-cards", "load-more"]
        },
        {
          "id": "footer",
          "name": "底部导航",
          "type": "footer",
          "height": "56px",
          "components": ["home-tab", "discover-tab", "post-tab", "notification-tab", "profile-tab"]
        }
      ]
    },
    "aiPrompt": {
      "title": "社交动态流（移动端）",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "顶部导航（Logo+搜索+消息）、故事/状态轮播区、动态卡片列表、底部导航栏（5个Tab）"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 故事区：圆形头像横向滚动，未查看带边框\n2. 动态卡片：用户信息+内容+图片+互动按钮（点赞、评论、分享）\n3. 底部导航：首页、发现、发布、通知、我的\n4. 下拉刷新，上拉加载更多"
        }
      ]
    }
  },
  {
    "id": "social-profile-mobile",
    "name": "个人主页-移动端",
    "scene": "social",
    "device": "mobile",
