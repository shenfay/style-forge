      "primaryColor": "#5F7D2E",
      "cornerRadius": "large",
      "cardStyle": "shadow",
      "titleBarStyle": "colored-bg",
      "switcherStyle": "underline",
      "buttonStyle": "gradient",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "顶部导航",
          "type": "header",
          "height": "44px",
          "components": ["back-button", "title", "settings-button"]
        },
        {
          "id": "profile-header",
          "name": "个人信息区",
          "type": "content",
          "components": ["avatar", "username", "bio", "stats", "action-buttons"]
        },
        {
          "id": "content",
          "name": "内容区",
          "type": "content",
          "components": ["tabs", "content-grid"]
        }
      ]
    },
    "aiPrompt": {
      "title": "社交个人主页（移动端）",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "顶部导航、个人信息区（头像+昵称+简介+数据统计+操作按钮）、内容切换标签（动态、照片、喜欢）、内容网格"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 个人信息：大头像、昵称、简介文字\n2. 数据统计：关注数、粉丝数、获赞数\n3. 操作按钮：关注/已关注、发消息\n4. 内容网格：3列图片网格或列表视图"
        }
      ]
    }
  }
