      "titleBarStyle": "white-underline",
      "switcherStyle": "underline",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "two-column",
      "regions": [
        {
          "id": "sidebar",
          "name": "侧边导航",
          "type": "sidebar",
          "components": ["logo", "nav-menu", "spacer", "user-profile"]
        },
        {
          "id": "header",
          "name": "顶部栏",
          "type": "header",
          "height": "64px",
          "components": ["breadcrumb", "search", "notifications", "user-menu"]
        },
        {
          "id": "content",
          "name": "主内容区",
          "type": "content",
          "components": ["welcome-banner", "stats-cards", "quick-actions", "recent-activity"]
        }
      ]
    },
    "aiPrompt": {
      "title": "PC端首页",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "左侧导航栏（Logo+菜单+用户信息）、顶部栏（面包屑+搜索+通知+用户菜单）、主内容区（欢迎横幅+统计卡片+快捷操作+最近动态）"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 侧边导航：可折叠菜单，支持多级\n2. 统计卡片：4个核心指标\n3. 快捷操作：6个常用功能按钮\n4. 最近动态：时间线列表"
        }
      ]
    }
  },
