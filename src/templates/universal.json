[
  {
    "id": "universal-home-mobile",
    "name": "首页-移动端",
    "scene": "universal",
    "device": "mobile",
    "type": "home",
    "description": "移动端应用首页，展示核心功能入口和内容推荐",
    "defaultStyle": {
      "backgroundColor": "#FFFFFF",
      "primaryColor": "#0066FF",
      "cornerRadius": "medium",
      "cardStyle": "shadow",
      "titleBarStyle": "frosted-glass",
      "switcherStyle": "pill",
      "buttonStyle": "solid",
      "badgeStyle": "rounded"
    },
    "layout": {
      "type": "single-column",
      "regions": [
        {
          "id": "header",
          "name": "顶部导航",
          "type": "header",
          "height": "44px",
          "components": ["logo", "search-bar", "message-icon"]
        },
        {
          "id": "banner",
          "name": "轮播图",
          "type": "content",
          "components": ["banner-swiper", "dots-indicator"]
        },
        {
          "id": "quick-actions",
          "name": "快捷入口",
          "type": "content",
          "components": ["icon-grid", "action-buttons"]
        },
        {
          "id": "recommendations",
          "name": "推荐内容",
          "type": "content",
          "components": ["section-title", "card-list", "load-more"]
        },
        {
          "id": "tabbar",
          "name": "底部导航",
          "type": "footer",
          "height": "56px",
          "components": ["tab-home", "tab-discover", "tab-messages", "tab-profile"]
        }
      ]
    },
    "aiPrompt": {
      "title": "移动端首页",
      "sections": [
        {
          "heading": "## 页面结构",
          "content": "顶部导航栏（Logo+搜索+消息）、轮播图、快捷功能入口网格、推荐内容列表、底部Tab栏"
        },
        {
          "heading": "## 组件要求",
          "content": "1. 搜索栏：支持文字输入和语音搜索\n2. 轮播图：自动轮播，支持手势滑动\n3. 快捷入口：4-6个图标按钮\n4. 推荐卡片：图文混排，支持左右滑动\n5. 底部Tab：4个标签，当前选中高亮"
        },
        {
          "heading": "## 交互说明",
          "content": "- 下拉刷新内容\n- 轮播图支持手动滑动和自动播放\n- 底部Tab切换页面\n- 卡片点击跳转到详情"
        }
      ]
    }
  },
  {
    "id": "universal-home-desktop",
